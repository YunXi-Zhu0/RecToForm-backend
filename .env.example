API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*

REDIS_URL=redis://127.0.0.1:6379/0
RQ_QUEUE_NAME=invoice_tasks
RQ_JOB_TIMEOUT=1800
RQ_RESULT_TTL=86400
RQ_WORKER_PROCESSES=4

WORKFLOW_ASYNC_CONCURRENCY=15
MAX_UPLOAD_FILES=50
MAX_FILE_SIZE_MB=10

LLM_PROVIDER=qwen_local_openai_compatible
QWEN3_VL_PLUS_API_KEY=
QWEN3_VL_PLUS_TEMPERATURE=0.7
QWEN3_VL_PLUS_MAX_TOKENS=500

QWEN3_VL_8B_SSPU_API_URL=
QWEN3_VL_8B_SSPU_MODEL_NAME=/model/Qwen3-VL-8B
QWEN3_VL_8B_SSPU_TEMPERATURE=0.7
QWEN3_VL_8B_SSPU_MAX_TOKENS=500
QWEN3_VL_8B_SSPU_TIMEOUT=30
QWEN3_VL_8B_SSPU_MAX_IMAGE_SIZE=1024
QWEN3_VL_8B_SSPU_IMAGE_QUALITY=85
